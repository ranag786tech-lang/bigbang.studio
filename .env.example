# Example environment variables

# GROQ / AI provider API key (server only)
GROQ_API_KEY=your_groq_api_key_here

# Supabase: only needed server-side if you do server-to-Supabase admin operations.
# Do NOT store service_role keys in the client.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here
